{
  "title": "Monitoramento Projeto Korp",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,

  "panels": [

    {
      "title": "Total de Requisições",
      "type": "stat",

      "targets": [
        {
          "expr": "http_requests_total"
        }
      ],

      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },

    {
      "title": "Disponibilidade",

      "type": "gauge",

      "targets": [
        {
          "expr": "up"
        }
      ],

      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },

    {
      "title": "Requisições por Segundo",

      "type": "timeseries",

      "targets": [
        {
          "expr": "rate(http_requests_total[1m])"
        }
      ],

      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 10
      }
    }

  ]
}